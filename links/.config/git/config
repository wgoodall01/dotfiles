[user]
	email = wgoodall01@gmail.com
	name = William Goodall

[alias]
	lgl = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) %C(bold green)%<(15)%ar%C(reset) %C(white)%s%C(reset) %C(dim white)- %aN%C(reset)%C(bold yellow)%d%C(reset)' --all
	lg = "lgl -n 20"
	browse = !"gh browse"
	s = "status -u"
	a = "add"
	aa = "add --all"
	c = "commit -m"
	ds = "diff --staged"
	df = "diff"
	ff = "merge --ff-only"
	fa = "fetch --all"
	amend = "commit --amend --no-edit"
	sweep = "stash -k -u"
	wt = "worktree"
	uncommit = "reset --soft HEAD~"
	remain = "!git fetch origin && git rebase origin/main"

	# Create topic branches, create PRs to get them merged.
	topic = "!f() { git fetch --all -q; git show-ref --verify --quiet refs/heads/$1 && git checkout $1 || git checkout --no-track origin/main -b $1; }; f"
	pr = !"gh pr view -w || (git push origin HEAD && gh pr new -w --title \"$(git branch --show-current)\")"

	# Open the Linear ticket for the current branch
	lin = "!open \"https://linear.app/allgood/issue/$(git symbolic-ref --short HEAD | grep -oE '^[A-Z]+-[0-9]+')\""

	# Force push the current branch with lease
	fpl = !"git push --force-with-lease origin $(git symbolic-ref --short HEAD)"

[diff]
	submodule = "log"

[push]
	default = upstream
	autoSetupRemote = true

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[log]
	mailmap = true

[mailmap]
	file = ~/.config/git/mailmap

[merge]
	tool = bc4
	conflictStyle = "diff3"

[mergetool "bc4"]
	trustExitCode = true

[init]
	defaultBranch = main
	
[core]
	hooksPath = $HOME/.config/git/hooks/
